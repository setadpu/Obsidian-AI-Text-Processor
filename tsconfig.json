{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "obsidian": ["./node_modules/obsidian/obsidian.d.ts"]
    },
    "lib": ["DOM", "ES5", "ES6", "ES7", "ES2022"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}